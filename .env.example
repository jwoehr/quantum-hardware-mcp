# Copy this file to .env and fill in your real values.
# -------------------------------------------------------

# IBM Quantum API token (required)
# Get your token at: https://quantum.ibm.com/account
IBM_QUANTUM_TOKEN=your_token_here

# IBM account configuration (optional)
# IBM_CHANNEL sets the platform: ibm_quantum_platform (default) or ibm_cloud
# IBM_INSTANCE pins a specific hub/group/project (e.g. ibm-q/open/main).
# Leave unset to let IBM auto-select based on your account's available plans.
# IBM_CHANNEL=ibm_quantum_platform
# IBM_INSTANCE=ibm-q/open/main

# Set to "false" to hide IBM account info from the server startup banner.
# Useful if you consider your instance/channel settings confidential.
# IBM_SHOW_ACCOUNT_INFO=true

# -------------------------------------------------------
# LLM Provider (pick ONE — default is anthropic)
# Supported: anthropic, gemini, ollama, openai, vllm
# -------------------------------------------------------
LLM_PROVIDER=anthropic

# --- Option 1: Anthropic (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Option 2: Google Gemini (free tier available) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Option 3: Ollama (free, runs locally, no API key needed) ---
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434   # default, change if remote

# --- Option 4: OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Option 5: vLLM (self-hosted open-source models) ---
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://your-vllm-server:8000
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# -------------------------------------------------------
# HTTP Server Configuration (optional)
# -------------------------------------------------------
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
MCP_CORS_ORIGINS=*

# API Key Authentication (optional, recommended for production)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
#MCP_API_KEY=your_secure_api_key_here
