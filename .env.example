# Copy this file to .env and fill in your real values.
# -------------------------------------------------------

# IBM Quantum API token (required)
# Get your token at: https://quantum.ibm.com/account
IBM_QUANTUM_TOKEN=your_token_here

# -------------------------------------------------------
# LLM Provider (pick ONE — default is anthropic)
# Supported: anthropic, gemini, ollama, openai, vllm
# -------------------------------------------------------
LLM_PROVIDER=anthropic

# --- Option 1: Anthropic (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Option 2: Google Gemini (free tier available) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Option 3: Ollama (free, runs locally, no API key needed) ---
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434   # default, change if remote

# --- Option 4: OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Option 5: vLLM (self-hosted open-source models) ---
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://your-vllm-server:8000
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# -------------------------------------------------------
# Qiskit Specialist Code Model (optional)
# A local AI model tuned specifically for Qiskit/quantum code.
# Runs via Ollama — free, no API key, fully local.
# Leave unset to disable. When set, the agent gets a 3rd action:
# call this model for quantum code questions instead of the main LLM.
# -------------------------------------------------------
# Recommended: IBM's own Mistral model (the one behind Qiskit Code Assistant)
# To install: ollama pull hf.co/Qiskit/mistral-small-3.2-24b-qiskit-GGUF:latest
#QISKIT_CODE_MODEL=hf.co/Qiskit/mistral-small-3.2-24b-qiskit-GGUF:latest
#QISKIT_CODE_MODEL_URL=http://localhost:11434

# Smaller/faster alternative (good for low-RAM machines, no GPU):
#QISKIT_CODE_MODEL=hf.co/Qiskit/granite-3.3-8b-qiskit-GGUF:latest

# Timeout for the Qiskit model call in milliseconds.
# Default is 600000 (10 minutes) — needed for CPU-only machines without a GPU.
# Reduce if you have a GPU and want faster failure detection.
#QISKIT_MODEL_TIMEOUT_MS=600000

# -------------------------------------------------------
# HTTP Server Configuration (optional)
# -------------------------------------------------------
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
MCP_CORS_ORIGINS=*

# API Key Authentication (optional, recommended for production)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
#MCP_API_KEY=your_secure_api_key_here
