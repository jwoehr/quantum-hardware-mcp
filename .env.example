# Copy this file to .env and fill in your real token.
# Get your token at: https://quantum.ibm.com/account
# IBM Quantum API token (required)
# Get your token at https://quantum.ibm.com/account
IBM_QUANTUM_TOKEN=your_token_here

# HTTP Server Configuration (optional, only used with --transport http)
# Default values shown below
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
MCP_CORS_ORIGINS=*

# API Key Authentication (optional, recommended for production HTTP mode)
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If not set, HTTP server runs without authentication (development mode only)
#MCP_API_KEY=your_secure_api_key_here
