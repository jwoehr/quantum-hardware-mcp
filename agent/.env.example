# Quantum Hardware MCP Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM Provider Selection
# ============================================================================
# Choose which LLM provider to use: gemini, ollama, openai, anthropic, or vllm
LLM_PROVIDER=gemini

# ============================================================================
# Google Gemini Configuration (if LLM_PROVIDER=gemini)
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
# Other available models: gemini-1.5-pro, gemini-1.5-flash

# ============================================================================
# Ollama Configuration (if LLM_PROVIDER=ollama)
# ============================================================================
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# Other recommended models:
#   - llama3.1:70b (higher accuracy, requires more resources)
#   - mistral:7b (fast responses)
#   - codellama:13b (better for technical queries)
#   - qwen2.5-coder:7b (optimized for coding tasks)
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_KEEP_ALIVE=5m

# ============================================================================
# OpenAI Configuration (if LLM_PROVIDER=openai)
# ============================================================================
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# Other available models: gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# OPENAI_TEMPERATURE=0.7
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional, for compatible APIs

# ============================================================================
# Anthropic Configuration (if LLM_PROVIDER=anthropic)
# ============================================================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Other available models: claude-3-opus-20240229, claude-3-sonnet-20240229
# ANTHROPIC_TEMPERATURE=0.7
# ANTHROPIC_MAX_TOKENS=4096

# ============================================================================
# vLLM Configuration (if LLM_PROVIDER=vllm)
# ============================================================================
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# VLLM_API_KEY=EMPTY  # Optional, defaults to "EMPTY" for local vLLM
# VLLM_TEMPERATURE=0.7
# VLLM_MAX_TOKENS=4096
# VLLM_TOP_P=0.95

# ============================================================================
# Quantum Hardware MCP Server Configuration (Required for all providers)
# ============================================================================
# FastMCP default endpoint is /sse
QUANTUM_MCP_SERVER_URI=http://127.0.0.1:3020/mcp

# MCP Server API Key (Required if quantum-hardware-mcp server has authentication enabled)
# Leave empty or comment out if server doesn't require authentication
MCP_API_KEY=your_mcp_api_key_here

# ============================================================================
# Agent Server Configuration (Optional)
# ============================================================================
# PORT=3021
# QUANTUM_AGENT_URL=http://localhost:3021
# QUANTUM_MCP_AGENT_SKILLS_PATH=/path/to/quantum-agent-skills/skills
# MAX_ITERATIONS=10
# SESSION_TIMEOUT_MS=300000

# ============================================================================
# Debug Configuration (Optional)
# ============================================================================
# DEBUG=TRUE

# ============================================================================
# Concurrency and Timeouts
# ============================================================================
# LLM_CONCURRENCY=4
# MCP_CONCURRENCY=8
# LLM_TIMEOUT_MS=60000
# MCP_TIMEOUT_MS=30000

# ============================================================================
# IonQ Configuration (Optional — for IonQ subagent)
# Get your key at: https://cloud.ionq.com/settings/keys
# ============================================================================
# IONQ_API_KEY=your_ionq_api_key_here

# ============================================================================
# Qiskit Specialist Code Model (Optional)
# A local AI model tuned specifically for Qiskit/quantum code.
# Runs via Ollama — free, no API key, fully local.
# When set, the agent routes quantum code questions to this model instead of
# the main LLM. Leave unset to disable.
# ============================================================================
# Recommended: IBM's own Mistral model (the one behind Qiskit Code Assistant)
# To install: ollama pull hf.co/Qiskit/mistral-small-3.2-24b-qiskit-GGUF:latest
# QISKIT_CODE_MODEL=hf.co/Qiskit/mistral-small-3.2-24b-qiskit-GGUF:latest
# QISKIT_CODE_MODEL_URL=http://localhost:11434

# Smaller/faster alternative (good for low-RAM machines, no GPU):
# QISKIT_CODE_MODEL=hf.co/Qiskit/granite-3.3-8b-qiskit-GGUF:latest

# Timeout for the Qiskit model call in milliseconds.
# Default is 600000 (10 minutes) — needed for CPU-only machines without a GPU.
# QISKIT_MODEL_TIMEOUT_MS=600000